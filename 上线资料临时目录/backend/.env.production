# 服务器配置
PORT=8080
NODE_ENV=production

# MongoDB配置 (生产环境)
MONGODB_URI=mongodb+srv://admin:password@cluster0.example.mongodb.net/tea_sea_shrimp_king
MONGODB_DB_NAME=tea_sea_shrimp_king

# Redis配置 (生产环境)
REDIS_HOST=redis-12345.c10.us-east-1-4.ec2.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-password

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# CORS配置
CORS_ORIGIN=https://www.tea-sea-shrimp-king.com,https://tea-sea-shrimp-king.com

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 金融数据API配置
FINANCE_API_KEY=your-finance-api-key
FINANCE_API_BASE_URL=https://api.finance.com/v1

# 支付系统配置
PAYMENT_API_KEY=your-payment-api-key
PAYMENT_API_SECRET=your-payment-api-secret
PAYMENT_API_BASE_URL=https://api.payment.com/v1
PAYMENT_SUCCESS_URL=https://www.tea-sea-shrimp-king.com/payment/success
PAYMENT_CANCEL_URL=https://www.tea-sea-shrimp-king.com/payment/cancel
PAYMENT_WEBHOOK_SECRET=your-webhook-secret-key

# AI分析配置
AI_API_KEY=your-ai-api-key
AI_API_BASE_URL=https://api.ai.com/v1
AI_MODEL=gpt-4

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/server.log

# 监控配置
MONITORING_API_KEY=your-monitoring-api-key
MONITORING_ENDPOINT=https://monitoring.example.com/api

# 安全配置
SECURE_COOKIE=true
HTTPS_ENABLED=true
