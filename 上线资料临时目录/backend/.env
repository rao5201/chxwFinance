# 服务器配置
PORT=3022
NODE_ENV=development

# MongoDB配置 (使用MongoDB Atlas云服务)
MONGODB_URI=mongodb+srv://admin:password@cluster0.example.mongodb.net/tea_sea_shrimp_king
MONGODB_DB_NAME=tea_sea_shrimp_king

# Redis配置 (使用Redis Cloud云服务)
REDIS_HOST=redis-12345.c10.us-east-1-4.ec2.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-password

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# 安全配置
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS配置
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# AI服务配置
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your-ai-api-key

# 金融数据API配置
FINANCE_API_KEY=your-finance-api-key
FINANCE_API_URL=https://api.finance-data.com

# 支付配置
PAYMENT_GATEWAY_URL=https://api.payment-gateway.com
PAYMENT_API_KEY=your-payment-api-key

# 第三方接入配置
CHXW_V53_API_URL=https://api.chxw-v53.com
CHXW_V53_API_KEY=your-chxw-api-key

# 腾讯文档配置
TENCENT_DOCS_MCP_TOKEN=346ff373be3c4dbbbdaa78d34a147dfb
TENCENT_DOCS_API_URL=https://docs.qq.com/api/v1

# 邮件配置
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=alerts@tea-sea-shrimp-king.com
SMTP_PASS=YCnWHYQgqYeytZxx
ALERT_EMAIL_FROM=alerts@tea-sea-shrimp-king.com
ALERT_EMAIL_TO=admin@tea-sea-shrimp-king.com
